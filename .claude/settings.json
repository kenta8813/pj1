{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '{\"systemMessage\":\"📝 セッション終了: memory.md の更新を確認してください\",\"hookSpecificOutput\":{\"hookEventName\":\"Stop\",\"additionalContext\":\"セッション終了前チェック（必須）: /home/user/pj1/memory.md を最新の進捗・決定事項に更新してください。memory.md の冒頭に「セッション終了前に更新する」と明記されています。未更新の場合は今すぐ更新してコミットしてください。\"}}'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(composer *)",
      "Bash(php artisan *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "Skill"
    ],
    "deny": [
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | bash)",
      "Bash(wget * | sh)",
      "Bash(curl *-d*.env*)",
      "Bash(curl *--data*.env*)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(* > /dev/tcp/*)",
      "Bash(ssh * -R *)",
      "Bash(scp *)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/credentials)",
      "Read(**/.aws/*)",
      "Read(**/.ssh/*)"
    ]
  },
  "mcpServers": {
    "laravel-boost": {
      "command": "php",
      "args": ["artisan", "boost:mcp"],
      "cwd": "packages/collector"
    },
    "next-devtools": {
      "command": "npx",
      "args": ["-y", "next-devtools-mcp@latest"]
    }
  }
}
