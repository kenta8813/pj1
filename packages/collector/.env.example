APP_NAME=Collector
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ── Laravel AI SDK ───────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_URL=https://openrouter.ai/api/v1
OLLAMA_API_KEY=
OLLAMA_URL=http://localhost:11434
OPENAI_API_KEY=

# ── LLMモデル ────────────────────────────────────────────
LLM_MODEL=google/gemini-2.0-flash-exp:free

# ── クローラー ───────────────────────────────────────────
CRAWLER_TIMEOUT=30
CRAWLER_RATE_LIMIT_MS=1000
CRAWLER_MAX_DEPTH=3
CRAWLER_USER_AGENT="Mozilla/5.0 (compatible; ChildcareBot/1.0)"
CRAWLER_RESPECT_ROBOTS=true
CRAWLER_MAX_HTML_CHARS=12000

# ── キュー ───────────────────────────────────────────────
QUEUE_CONNECTION=database

# ── データベース ─────────────────────────────────────────
DB_CONNECTION=sqlite

# ── 収集対象URL ──────────────────────────────────────────
COLLECT_TARGET_1_URL=
